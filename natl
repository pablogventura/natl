#!/usr/bin/env python3
"""
natl - Natural Language to Linux
Translates natural language instructions into a single shell command (Ollama).
The command is printed to stdout for insertion into the prompt without being run.
With no arguments: interactive configuration menu.
"""

import argparse
import json
import math
import os
import re
import shlex
import subprocess
import sys
import urllib.error
import urllib.request

# Directorio del script (resuelve symlinks para funcionar desde ~/bin)
SCRIPT_DIR = os.path.dirname(os.path.abspath(os.path.realpath(__file__)))
PROMPT_FILE = os.path.join(SCRIPT_DIR, "prompt.txt")

CONFIG_DIR = os.path.join(
    os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config")),
    "natl",
)
CONFIG_FILE = os.path.join(CONFIG_DIR, "config.json")

DATA_DIR = os.path.join(
    os.environ.get("XDG_DATA_HOME", os.path.expanduser("~/.local/share")),
    "natl",
)
DEFAULT_MAN_INDEX_PATH = os.path.join(DATA_DIR, "man_index.json")
VERSION_FILE = os.path.join(SCRIPT_DIR, "VERSION")

DEFAULT_OLLAMA_URL = "http://localhost:11434"
DEFAULT_MODEL = "llama3.2"

DANGEROUS_PATTERNS = [
    r"rm\s+-rf\s+/",
    r"rm\s+-rf\s+/\s",
    r"mkfs\.",
    r"\bdd\s+if=.*of=/dev",
    r":\s*\(\s*\)\s*\{.*\|:\s*&\s*\}\s*;?\s*:",
    r">\s*/dev/sd",
    r"chmod\s+-R\s+777\s+/",
]

DEFAULT_CONFIG = {
    "model": DEFAULT_MODEL,
    "ollama_url": DEFAULT_OLLAMA_URL,
    "prompt_suffix": "",
    "explain_default": False,
    "use_rag": False,
    "embedding_model": "nomic-embed-text",
    "man_index_path": DEFAULT_MAN_INDEX_PATH,
    "man_top_k": 5,
    "man_max_pages": 500,  # max man pages to index (None = all); limits build time and index size
}


def get_version() -> str:
    """Read version from VERSION file next to the script, or fallback."""
    if os.path.isfile(VERSION_FILE):
        try:
            with open(VERSION_FILE, encoding="utf-8") as f:
                return f.read().strip() or "0.1.0"
        except OSError:
            pass
    return "0.1.0"


def load_config() -> dict:
    if not os.path.isfile(CONFIG_FILE):
        return DEFAULT_CONFIG.copy()
    try:
        with open(CONFIG_FILE, encoding="utf-8") as f:
            data = json.load(f)
        return {**DEFAULT_CONFIG, **data}
    except (json.JSONDecodeError, OSError):
        return DEFAULT_CONFIG.copy()


def save_config(cfg: dict) -> None:
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(CONFIG_FILE, "w", encoding="utf-8") as f:
        json.dump(cfg, f, indent=2, ensure_ascii=False)


def fetch_ollama_models(base_url: str) -> list[str]:
    try:
        req = urllib.request.Request(
            f"{base_url.rstrip('/')}/api/tags",
            method="GET",
        )
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read().decode("utf-8"))
        return [m.get("name", "").split(":")[0] for m in data.get("models", [])]
    except Exception:
        return []


def check_ollama_reachable(base_url: str, timeout: int = 3) -> bool:
    """Return True if Ollama responds at base_url, else False."""
    try:
        req = urllib.request.Request(
            f"{base_url.rstrip('/')}/api/tags",
            method="GET",
        )
        with urllib.request.urlopen(req, timeout=timeout) as _:
            return True
    except Exception:
        return False


def call_ollama_embed(base_url: str, model: str, text: str, timeout: int = 60) -> list[float]:
    """Get embedding vector for text from Ollama. Returns list of floats."""
    body = json.dumps(
        {"model": model, "input": text},
        ensure_ascii=False,
    ).encode("utf-8")
    req = urllib.request.Request(
        f"{base_url.rstrip('/')}/api/embed",
        data=body,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        data = json.loads(resp.read().decode("utf-8"))
    # Single input returns "embedding", multiple return "embeddings"
    emb = data.get("embedding") or (data.get("embeddings") or [[]])[0]
    return emb if isinstance(emb, list) else []


def cosine_similarity(a: list[float], b: list[float]) -> float:
    if not a or not b or len(a) != len(b):
        return 0.0
    dot = sum(x * y for x, y in zip(a, b))
    na = math.sqrt(sum(x * x for x in a))
    nb = math.sqrt(sum(x * x for x in b))
    if na == 0 or nb == 0:
        return 0.0
    return dot / (na * nb)


def warn_ollama_unreachable(base_url: str) -> None:
    """Print a clear message and exit when Ollama is not reachable."""
    url = base_url.rstrip("/")
    local = "localhost" in url or "127.0.0.1" in url
    print("natl: could not connect to Ollama.", file=sys.stderr)
    if local:
        print(
            "Ollama is not running on this machine. Start the server with: ollama serve",
            file=sys.stderr,
        )
    else:
        print(f"Check that the service is running at {url}", file=sys.stderr)
    sys.exit(1)


def list_man_pages(section: int | None = 1) -> list[str]:
    """Return list of man page names (e.g. ['ls', 'find']). Section 1 = user commands."""
    try:
        result = subprocess.run(
            ["man", "-w"],
            capture_output=True,
            text=True,
            timeout=5,
            env={**os.environ, "MANPATH": os.environ.get("MANPATH", "")},
        )
        if result.returncode != 0 or not result.stdout.strip():
            return []
        paths = result.stdout.strip().split(":")
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return []
    names: set[str] = set()
    for path in paths:
        if not os.path.isdir(path):
            continue
        for root, _dirs, files in os.walk(path):
            for f in files:
                if not f.endswith(".gz"):
                    continue
                # e.g. ls.1.gz -> ls, printf.3.gz -> printf
                base = f[:-3]  # strip .gz
                if "." in base:
                    name, sec = base.rsplit(".", 1)
                    if section is None or sec == str(section):
                        names.add(name)
    return sorted(names)


def get_man_text(name: str) -> str:
    """Get plain text content of a man page."""
    try:
        result = subprocess.run(
            ["man", "--no-hyphenation", name],
            capture_output=True,
            text=True,
            timeout=10,
            env={**os.environ, "COLUMNS": "80", "MANPAGER": "cat"},
        )
        if result.returncode == 0 and result.stdout:
            return result.stdout.strip()
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    return ""


def split_pipeline(cmd: str) -> list[str]:
    """Split command by | respecting single quotes, double quotes and backslash."""
    parts: list[str] = []
    current: list[str] = []
    i = 0
    in_single = False
    in_double = False
    while i < len(cmd):
        c = cmd[i]
        if c == "'" and not in_double:
            in_single = not in_single
            current.append(c)
            i += 1
        elif c == '"' and not in_single:
            in_double = not in_double
            current.append(c)
            i += 1
        elif c == "\\" and i + 1 < len(cmd):
            current.append(c)
            current.append(cmd[i + 1])
            i += 2
        elif c == "|" and not in_single and not in_double:
            parts.append("".join(current).strip())
            current = []
            i += 1
        else:
            current.append(c)
            i += 1
    if current:
        parts.append("".join(current).strip())
    return parts


def parse_commands(cmd: str) -> list[str]:
    """Extract executable names from a shell command (pipeline). Returns unique names in order."""
    seen: set[str] = set()
    names: list[str] = []
    for part in split_pipeline(cmd):
        part = part.strip()
        if not part:
            continue
        try:
            tokens = shlex.split(part)
            for t in tokens:
                if "=" in t and not t.startswith("-") and not t.startswith("="):
                    continue
                name = t.split("/")[-1]
                if name and name not in seen:
                    seen.add(name)
                    names.append(name)
                break
        except ValueError:
            continue
    return names


def get_help_for_commands(command_names: list[str], max_chars_per_cmd: int = 4000) -> str:
    """Run --help (or -h) for each command and return concatenated output. Skips if not in PATH."""
    blocks: list[str] = []
    for name in command_names:
        if not name or not re.match(r"^[a-zA-Z0-9_.+-]+$", name):
            continue
        out = ""
        for flag in ("--help", "-h"):
            try:
                r = subprocess.run(
                    [name, flag],
                    capture_output=True,
                    text=True,
                    timeout=5,
                    env={**os.environ, "COLUMNS": "80", "LANG": "C"},
                )
                if r.returncode == 0 and (r.stdout or r.stderr):
                    out = (r.stdout or "").strip() + (("\n" + (r.stderr or "").strip()) if r.stderr else "")
                    break
            except (FileNotFoundError, subprocess.TimeoutExpired, OSError):
                continue
        if out:
            if len(out) > max_chars_per_cmd:
                out = out[:max_chars_per_cmd] + "\n... (truncated)"
            blocks.append(f"[{name}]\n{out}")
    if not blocks:
        return ""
    return "\n\n---\n\n".join(blocks)


def chunk_text(text: str, source: str, max_chars: int = 600) -> list[dict]:
    """Split man text into chunks. Each chunk has 'text' and 'source'."""
    chunks: list[dict] = []
    paragraphs = [p.strip() for p in text.split("\n\n") if p.strip()]
    current: list[str] = []
    current_len = 0
    for p in paragraphs:
        if current_len + len(p) + 2 > max_chars and current:
            chunks.append({"text": "\n\n".join(current), "source": source})
            current = []
            current_len = 0
        current.append(p)
        current_len += len(p) + 2
    if current:
        chunks.append({"text": "\n\n".join(current), "source": source})
    return chunks


def build_man_index(
    ollama_url: str,
    embedding_model: str,
    index_path: str,
    section: int = 1,
    max_pages: int | None = 500,
) -> None:
    """Build embedding index from man pages and save to index_path."""
    names = list_man_pages(section=section)
    if max_pages is not None:
        names = names[:max_pages]
    if not names:
        print("No man pages found.", file=sys.stderr)
        return
    os.makedirs(os.path.dirname(index_path) or ".", exist_ok=True)
    all_chunks: list[dict] = []
    total = len(names)
    for i, name in enumerate(names):
        text = get_man_text(name)
        if not text:
            continue
        source = f"{name}({section})"
        for c in chunk_text(text, source):
            all_chunks.append(c)
        if (i + 1) % 50 == 0:
            print(f"  Pages {i + 1}/{total} ...", file=sys.stderr)
    print(f"Embedding {len(all_chunks)} chunks with {embedding_model} ...", file=sys.stderr)
    for j, c in enumerate(all_chunks):
        try:
            c["embedding"] = call_ollama_embed(ollama_url, embedding_model, c["text"])
        except Exception as e:
            print(f"  Embedding failed for chunk: {e}", file=sys.stderr)
            c["embedding"] = []
        if (j + 1) % 20 == 0:
            print(f"  Chunks {j + 1}/{len(all_chunks)} ...", file=sys.stderr)
    out = {
        "embedding_model": embedding_model,
        "chunks": [{"text": c["text"], "source": c["source"], "embedding": c["embedding"]} for c in all_chunks if c.get("embedding")],
    }
    with open(index_path, "w", encoding="utf-8") as f:
        json.dump(out, f, indent=None, ensure_ascii=False)
    print(f"Index saved: {index_path} ({len(out['chunks'])} chunks)", file=sys.stderr)


def load_man_index(index_path: str) -> dict | None:
    """Load man index from JSON. Returns None if missing or invalid."""
    path = os.path.expanduser(index_path)
    if not os.path.isfile(path):
        return None
    try:
        with open(path, encoding="utf-8") as f:
            return json.load(f)
    except (json.JSONDecodeError, OSError):
        return None


def search_man_index(index: dict, query_embedding: list[float], top_k: int) -> list[dict]:
    """Return top_k chunks by cosine similarity to query_embedding."""
    chunks = index.get("chunks") or []
    if not query_embedding or not chunks:
        return []
    scored = [(cosine_similarity(c.get("embedding") or [], query_embedding), c) for c in chunks]
    scored.sort(key=lambda x: -x[0])
    return [c for _s, c in scored[:top_k]]


def run_config_menu() -> None:
    cfg = load_config()
    while True:
        print("\n--- natl: configuration ---")
        print("1) Ollama model       →", cfg["model"])
        print("2) Ollama URL        →", cfg["ollama_url"])
        suf = cfg["prompt_suffix"] or "(none)"
        print("3) Extra prompt instructions →", suf[:50] + ("..." if len(suf) > 50 else ""))
        print("4) Explanation by default    →", "yes" if cfg["explain_default"] else "no")
        print("5) List available models (Ollama)")
        print("6) View full config")
        print("7) Restore defaults")
        print("8) Use RAG (man pages)        →", "yes" if cfg.get("use_rag") else "no")
        print("9) Embedding model            →", cfg.get("embedding_model", DEFAULT_CONFIG["embedding_model"]))
        max_p = cfg.get("man_max_pages", DEFAULT_CONFIG["man_max_pages"])
        total_man = len(list_man_pages(section=1))
        max_str = str(max_p) if max_p else "all"
        print(f"10) Max pages to index       → {max_str} (of {total_man} total)")
        print("11) Build man page index (RAG)")
        print("0) Exit")
        try:
            op = input("\nOption [0]: ").strip() or "0"
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if op == "0":
            break
        if op == "1":
            val = input(f"Model [{cfg['model']}]: ").strip()
            if val:
                cfg["model"] = val
                save_config(cfg)
                print("Saved.")
        elif op == "2":
            val = input(f"Ollama URL [{cfg['ollama_url']}]: ").strip()
            if val:
                cfg["ollama_url"] = val.rstrip("/")
                save_config(cfg)
                print("Saved.")
        elif op == "3":
            print("Instructions appended to the end of the prompt (empty line to clear):")
            val = input("> ").strip()
            cfg["prompt_suffix"] = val
            save_config(cfg)
            print("Saved.")
        elif op == "4":
            cfg["explain_default"] = not cfg["explain_default"]
            save_config(cfg)
            print("Explanation by default:", "yes" if cfg["explain_default"] else "no")
        elif op == "5":
            models = fetch_ollama_models(cfg["ollama_url"])
            if models:
                print("Available models:", ", ".join(models))
            else:
                print("Could not fetch the list (is Ollama running?).")
        elif op == "6":
            print(json.dumps(cfg, indent=2, ensure_ascii=False))
        elif op == "7":
            cfg = DEFAULT_CONFIG.copy()
            save_config(cfg)
            print("Restored.")
        elif op == "8":
            cfg["use_rag"] = not cfg.get("use_rag", False)
            save_config(cfg)
            print("RAG (man pages):", "enabled" if cfg["use_rag"] else "disabled")
        elif op == "9":
            default_emb = cfg.get("embedding_model") or DEFAULT_CONFIG["embedding_model"]
            val = input(f"Embedding model [{default_emb}]: ").strip()
            if val:
                cfg["embedding_model"] = val
                save_config(cfg)
                print("Saved.")
        elif op == "10":
            default_mp = cfg.get("man_max_pages", DEFAULT_CONFIG["man_max_pages"])
            val = input(f"Max pages to index (0 = all) [{default_mp}]: ").strip()
            if val != "":
                try:
                    n = int(val)
                    cfg["man_max_pages"] = n if n != 0 else 0
                    save_config(cfg)
                    print("Saved.")
                except ValueError:
                    print("Enter a number.", file=sys.stderr)
        elif op == "11":
            if not check_ollama_reachable(cfg["ollama_url"]):
                print("Ollama is not available. Start the server (ollama serve).", file=sys.stderr)
            else:
                emb = cfg.get("embedding_model") or DEFAULT_CONFIG["embedding_model"]
                path = os.path.expanduser(cfg.get("man_index_path") or DEFAULT_MAN_INDEX_PATH)
                max_p = cfg.get("man_max_pages", DEFAULT_CONFIG["man_max_pages"])
                total_man = len(list_man_pages(section=1))
                if max_p:
                    print(f"Building index (section 1, max {max_p} of {total_man} total) ...", file=sys.stderr)
                else:
                    print(f"Building index (section 1, {total_man} pages total) ...", file=sys.stderr)
                build_man_index(cfg["ollama_url"], emb, path, section=1, max_pages=max_p or None)
        else:
            print("Invalid option.")
    print("Config saved to:", CONFIG_FILE)


ENRICH_PROMPT = """Restate the following user request in a clear, structured form. The user will use this to get a single Linux shell command.

- If there are multiple intents or steps, list them as short bullet points (•).
- Use one line or a few lines; be concise.
- Do NOT output a shell command, only the restated request.
- Output in the same language as the user.

User request: """


def enrich_user_request_with_llm(url: str, model: str, query: str, timeout: int = 15) -> str | None:
    """Ask the LLM to restate the user request in a structured way. Returns None on failure."""
    if not query.strip():
        return None
    try:
        prompt = ENRICH_PROMPT + query.strip()
        response = call_ollama(url, model, prompt, timeout=timeout)
        text = response.strip()
        if not text or len(text) < 2:
            return None
        first_block = text.split("\n\n")[0].strip()
        return first_block if first_block else text[:800].strip()
    except Exception:
        return None


def enrich_user_request(query: str) -> str:
    """Turn the raw user request into a structured block for the prompt (rule-based fallback)."""
    raw = " ".join(query.split()).strip()
    if not raw:
        return raw
    clause_re = re.compile(r"\s+and\s+|\s+then\s+|,\s*", re.IGNORECASE)
    parts = [p.strip() for p in clause_re.split(raw) if p.strip()]
    if len(parts) <= 1:
        structured = f"--- User request ---\n\n{raw}\n"
    else:
        bullets = "\n".join(f"• {p}" for p in parts)
        structured = f"--- User request (structured) ---\n\n{bullets}\n\nOriginal: {raw}\n"
    return structured + "\n--- End of request ---"


def get_prompt(
    query: str,
    prompt_path: str,
    suffix: str = "",
    man_docs: str = "",
    help_docs: str = "",
    request_text: str | None = None,
) -> str:
    if os.path.isfile(prompt_path):
        with open(prompt_path, encoding="utf-8") as f:
            template = f.read()
        template = template.replace("{man_docs}", man_docs)
        if help_docs:
            template = template.replace("{help_docs}", "\nRelevant command help:\n\n" + help_docs + "\n")
        else:
            template = template.replace("{help_docs}", "")
        if request_text is None:
            request_text = enrich_user_request(query)
        out = template.replace("{user_request}", request_text)
    else:
        out = (
            "Translate the user request to a single Linux shell command. "
            "Return ONLY the command. No explanations. Request: " + query
        )
    if suffix:
        out = out.rstrip() + "\n\n" + suffix.strip()
    return out


def call_ollama(url: str, model: str, prompt: str, timeout: int = 30) -> str:
    # Options for maximum determinism: temperature=0, fixed seed, top_k=1
    body = json.dumps(
        {
            "model": model,
            "prompt": prompt,
            "stream": False,
            "options": {
                "temperature": 0,
                "seed": 42,
                "top_k": 1,
            },
        },
        ensure_ascii=False,
    ).encode("utf-8")
    req = urllib.request.Request(
        f"{url.rstrip('/')}/api/generate",
        data=body,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            data = json.loads(resp.read().decode("utf-8"))
    except urllib.error.URLError as e:
        print(f"Error: could not connect to Ollama at {url}", file=sys.stderr)
        if hasattr(e, "reason"):
            print(str(e.reason), file=sys.stderr)
        sys.exit(1)
    except json.JSONDecodeError as e:
        print("Error: invalid response from Ollama", file=sys.stderr)
        print(str(e), file=sys.stderr)
        sys.exit(1)

    response = data.get("response") or data.get("error") or ""
    if not response and "error" in data:
        print(f"Error: {data['error']}", file=sys.stderr)
        sys.exit(1)
    if not response:
        print("Error: empty response from Ollama", file=sys.stderr)
        sys.exit(1)
    return response


def clean_command(raw: str) -> str:
    first_line = raw.strip().split("\n")[0].strip()
    first_line = re.sub(r"^\s*```[\w]*", "", first_line)
    first_line = re.sub(r"```\s*$", "", first_line)
    return first_line.strip()


def is_dangerous(cmd: str) -> bool:
    for pattern in DANGEROUS_PATTERNS:
        if re.search(pattern, cmd):
            return True
    return False


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Translate natural language to a Linux command (Ollama). No args: configuration menu."
    )
    parser.add_argument(
        "-m", "--model",
        default=None,
        help="Ollama model (overrides config)",
    )
    parser.add_argument(
        "-e", "--explain",
        action="store_true",
        default=None,
        help="Ask the LLM for a brief explanation (debugging)",
    )
    parser.add_argument(
        "-V", "--version",
        action="version",
        version="%(prog)s " + get_version(),
        help="Show version and exit",
    )
    parser.add_argument(
        "--build-man-index",
        action="store_true",
        help="Build embedding index from man pages (for RAG) and exit",
    )
    parser.add_argument(
        "--man-max-pages",
        type=int,
        default=None,
        metavar="N",
        help="When building index: max man pages to index (default: from config, or 500). Use 0 for no limit.",
    )
    parser.add_argument(
        "-v", "--verbose",
        action="store_true",
        help="Show model, RAG usage, full prompt, and LLM response on stderr",
    )
    parser.add_argument(
        "query",
        nargs="*",
        help="Natural language text",
    )
    args = parser.parse_args()
    verbose = args.verbose

    cfg = load_config()
    ollama_url = os.environ.get("OLLAMA_URL") or cfg["ollama_url"]

    if args.build_man_index:
        if not check_ollama_reachable(ollama_url):
            warn_ollama_unreachable(ollama_url)
        emb_model = cfg.get("embedding_model") or DEFAULT_CONFIG["embedding_model"]
        index_path = os.path.expanduser(cfg.get("man_index_path") or DEFAULT_MAN_INDEX_PATH)
        max_pages = args.man_max_pages if args.man_max_pages is not None else cfg.get("man_max_pages", DEFAULT_CONFIG["man_max_pages"])
        if max_pages == 0:
            max_pages = None
        total_man = len(list_man_pages(section=1))
        if max_pages is not None:
            print(f"Building man page index (section 1, max {max_pages} of {total_man} total) ...", file=sys.stderr)
        else:
            print(f"Building man page index (section 1, {total_man} pages total) ...", file=sys.stderr)
        build_man_index(ollama_url, emb_model, index_path, section=1, max_pages=max_pages)
        sys.exit(0)

    query = " ".join(args.query).strip()
    if not query:
        run_config_menu()
        sys.exit(0)

    model = args.model or os.environ.get("NATL_MODEL") or cfg["model"]
    explain = args.explain or cfg["explain_default"]
    prompt_suffix = cfg.get("prompt_suffix", "")

    man_docs_block = ""
    rag_used = False
    rag_sources: list[str] = []
    if cfg.get("use_rag"):
        index_path = os.path.expanduser(cfg.get("man_index_path") or DEFAULT_MAN_INDEX_PATH)
        index = load_man_index(index_path)
        if index and check_ollama_reachable(ollama_url):
            top_k = int(cfg.get("man_top_k") or 5)
            try:
                query_emb = call_ollama_embed(
                    ollama_url,
                    index.get("embedding_model") or cfg.get("embedding_model") or DEFAULT_CONFIG["embedding_model"],
                    query,
                )
                hits = search_man_index(index, query_emb, top_k)
                if hits:
                    rag_used = True
                    rag_sources = [c.get("source", "") for c in hits]
                    parts = [f"[{c.get('source', '')}]\n{c.get('text', '')}" for c in hits]
                    man_docs_block = "\n\n---\n\n".join(parts)
                    man_docs_block = "\nRelevant documentation (use only to pick command and flags):\n\n" + man_docs_block + "\n"
            except Exception:
                pass

    if verbose:
        print("--- natl (verbose) ---", file=sys.stderr)
        print(f"Ollama URL: {ollama_url}", file=sys.stderr)
        print(f"Model: {model}", file=sys.stderr)
        print(f"RAG (man pages): {'yes' if rag_used else 'no'}", file=sys.stderr)
        if rag_used:
            print(f"  Embedding model: {index.get('embedding_model', '')}", file=sys.stderr)
            print(f"  Chunks injected: {len(rag_sources)} → {', '.join(rag_sources)}", file=sys.stderr)
        print("", file=sys.stderr)

    if not check_ollama_reachable(ollama_url):
        warn_ollama_unreachable(ollama_url)

    llm_structured = enrich_user_request_with_llm(ollama_url, model, query)
    if llm_structured:
        request_text = (
            "--- User request ---\n\n" + llm_structured + "\n\nOriginal: " + query + "\n\n--- End of request ---"
        )
        if verbose:
            print("--- Request enriched by LLM ---", file=sys.stderr)
            print(request_text, file=sys.stderr)
            print("", file=sys.stderr)
    else:
        request_text = enrich_user_request(query)

    prompt = get_prompt(
        query, PROMPT_FILE, prompt_suffix, man_docs=man_docs_block, request_text=request_text
    )
    if explain:
        prompt += "\n\nIf helpful, add one short line of explanation after the command, prefixed with # "

    raw = call_ollama(ollama_url, model, prompt)
    cmd = clean_command(raw)

    if verbose:
        print("--- Prompt sent to LLM ---", file=sys.stderr)
        print(prompt, file=sys.stderr)
        print("", file=sys.stderr)
        print("--- Raw LLM response ---", file=sys.stderr)
        print(raw, file=sys.stderr)
        print("", file=sys.stderr)

    command_names = parse_commands(cmd)
    help_block = get_help_for_commands(command_names) if command_names else ""
    if help_block:
        prompt2 = get_prompt(
            query,
            PROMPT_FILE,
            prompt_suffix,
            man_docs=man_docs_block,
            help_docs=help_block,
            request_text=request_text,
        )
        if explain:
            prompt2 += "\n\nIf helpful, add one short line of explanation after the command, prefixed with # "
        if verbose:
            print("--- Second prompt (with --help output) ---", file=sys.stderr)
            print(prompt2, file=sys.stderr)
            print("", file=sys.stderr)
        raw2 = call_ollama(ollama_url, model, prompt2)
        cmd = clean_command(raw2)
        if verbose:
            print("--- Raw LLM response (second pass) ---", file=sys.stderr)
            print(raw2, file=sys.stderr)
            print("", file=sys.stderr)

    if is_dangerous(cmd):
        cmd = "# WARNING: potentially destructive - review before running\n" + cmd
        if verbose:
            print("(Warning comment prepended: command matched dangerous pattern)", file=sys.stderr)

    if verbose:
        print("--- Final command (stdout) ---", file=sys.stderr)
        print(cmd, file=sys.stderr)
        print("---", file=sys.stderr)

    print(cmd)


if __name__ == "__main__":
    main()
